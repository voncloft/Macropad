  (text "Macropad Target: ESP32-S3 (Wi-Fi + BLE), IR TX/RX, LCD(I2C), WS2812/SK6812 LEDs" (at 20.32 11.43 0)
    (effects (font (size 1.6 1.6) (thickness 0.25)))
  )
  (text "Recommended controller: ESP32-S3-WROOM-1 module (Wi-Fi + Bluetooth)" (at 20.32 16.51 0)
    (effects (font (size 1.2 1.2) (thickness 0.2)))
  )
  (text "Matrix nets:" (at 20.32 21.59 0)
    (effects (font (size 1.8 1.8) (thickness 0.3)))
  )
  (text "Rows: ROW0, ROW1, ROW2, ROW3, ROW4, ROW5" (at 20.32 25.40 0)
    (effects (font (size 1.2 1.2) (thickness 0.2)))
  )
  (text "Cols: COL0, COL1, COL2, COL3, COL4" (at 20.32 29.21 0)
    (effects (font (size 1.2 1.2) (thickness 0.2)))
  )
  (text "Feature nets:" (at 20.32 34.29 0)
    (effects (font (size 1.8 1.8) (thickness 0.3)))
  )
  (text "IR: IR_TX output + IR_RX input (for TV/projector remote control codes)" (at 20.32 38.10 0)
    (effects (font (size 1.2 1.2) (thickness 0.2)))
  )
  (text "LED: RGB_DATA (MCU) -> 330R -> LED_DIN, plus 5V/GND (WS2812/SK6812 chain)" (at 20.32 41.91 0)
    (effects (font (size 1.2 1.2) (thickness 0.2)))
  )
  (text "LCD: SPI data/clock + power on J302; control (CS/DC/RST/BL) on J303" (at 20.32 44.45 0)
    (effects (font (size 1.2 1.2) (thickness 0.2)))
  )
  (text "Electrical notes: 330R in LED data line, 470uF+ cap on LED 5V rail, level shifter 3V3->5V for LED data." (at 20.32 45.72 0)
    (effects (font (size 1.1 1.1) (thickness 0.18)))
  )
  (text "Wireless features: Wi-Fi supported by MCU, plus IR control and rotary dial for volume." (at 20.32 49.53 0)
    (effects (font (size 1.2 1.2) (thickness 0.2)))
  )
  (text "Portable power: onboard USB-C charging (J402+U403), BAT+ feeds 3V3 LDO (U402) and 5V boost stage (U404+L401+D401)." (at 20.32 52.07 0)
    (effects (font (size 1.1 1.1) (thickness 0.18)))
  )
  (text "Mechanical requirement: include enclosure access to ESP32 EN/RESET and BOOT buttons for recovery flashing." (at 20.32 54.61 0)
    (effects (font (size 1.2 1.2) (thickness 0.2)))
  )
